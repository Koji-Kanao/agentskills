  "navigation": {
    "languages": [
      {
        "language": "en",
        "default": true,
        "pages": [
          "home",
          "what-are-skills",
          "specification",
          {
            "group": "For skill creators",
            "pages": [
              "skill-creation/quickstart",
              "skill-creation/best-practices",
              "skill-creation/optimizing-descriptions",
              "skill-creation/evaluating-skills",
              "skill-creation/using-scripts"
            ]
          },
          {
            "group": "For client implementors",
            "pages": ["client-implementation/adding-skills-support"]
          }
        ]
      },
      {
        "language": "jp",
        "pages": [
          "jp/home",
          "jp/what-are-skills",
          "jp/specification",
          {
            "group": "スキル作成者向け",
            "pages": [
              "jp/skill-creation/quickstart",
              "jp/skill-creation/best-practices",
              "jp/skill-creation/optimizing-descriptions",
              "jp/skill-creation/evaluating-skills",
              "jp/skill-creation/using-scripts"
            ]
          },
          {
            "group": "クライアント実装者向け",
            "pages": ["jp/client-implementation/adding-skills-support"]
          }
        ]
      }
    ]
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  },
  "redirects": [
    {
      "source": "/integrate-skills",
      "destination": "/client-implementation/adding-skills-support"
    },
    {
      "source": "/jp/integrate-skills",
      "destination": "/jp/client-implementation/adding-skills-support"
    }
  ]
}
