{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Agent Skills",
  "colors": {
    "primary": "#7f7f7f",
    "light": "#bfbfbf",
    "dark": "#404040"
  },
  "favicon": "/favicon.svg",
  "navbar": {
    "primary": {
      "type": "github",
      "href": "https://github.com/agentskills/agentskills"
    }
